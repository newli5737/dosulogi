# App
APP_PORT=8089
APP_ENV=production

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=dosulogi
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# JWT — generate secrets: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAY=7
JWT_ADMIN_REFRESH_TTL_DAY=14

# Auth cookies (required for cross-subdomain FE/API on production)
COOKIE_DOMAIN=.dosutech.site

# SePay
SEPAY_WEBHOOK_SECRET=<from-sepay-dashboard>

# Email
FROM_EMAIL=support@dosutech.site

# Company (hóa đơn PDF & branding)
COMPANY_NAME=CÔNG TY TNHH THƯƠNG MẠI & DỊCH VỤ DOSU
COMPANY_TAGLINE=Đối tác công nghệ tin cậy, xây dựng giải pháp toàn diện từ ý tưởng đến sản phẩm hoàn thiện.
COMPANY_TAX_CODE=
COMPANY_ADDRESS=Số 03, Ngách 72/59 Đường Tây Mỗ, Phường Tây Mỗ, TP Hà Nội
COMPANY_PHONE=0346 437 915 (Lại Thế Ngọc)
COMPANY_EMAIL=support@dosutech.site

# Tracking 3rd party (gps-tracker mock)
TRACKING_API_BASE_URL=http://127.0.0.1:8091
TRACKING_API_KEY=dev-gps-api-key
TRACKING_POLL_INTERVAL_SEC=30
TRACKING_WEBHOOK_SECRET=dev-tracking-secret

# Zalo bridge
ZALO_BRIDGE_URL=http://127.0.0.1:8090

# Uploads
UPLOAD_DIR=/home/dosulogi/uploads

# CORS
CORS_ORIGINS=https://logi.dosutech.site,http://logi.dosutech.site
