# App
APP_PORT=8089
APP_ENV=production

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=dosulogi
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=<random-256bit>
JWT_REFRESH_SECRET=<random-256bit>
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAY=7

# SePay
SEPAY_WEBHOOK_SECRET=<from-sepay-dashboard>

# Email
FROM_EMAIL=no-reply@dosulogi.com

# Tracking 3rd party
TRACKING_API_BASE_URL=https://api.trackingprovider.com
TRACKING_API_KEY=xxx
TRACKING_POLL_INTERVAL_SEC=300
TRACKING_WEBHOOK_SECRET=<webhook-hmac-secret>

# Uploads
UPLOAD_DIR=/home/dosulogi/uploads

# CORS
CORS_ORIGINS=https://logi.dosutech.site,http://logi.dosutech.site
